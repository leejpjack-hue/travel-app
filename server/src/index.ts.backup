      base_location: baseLocation,
      tour_radius: (trip as any).tour_radius || 5000,
      max_destinations: (trip as any).max_destinations || 5
    });
  } catch (error: any) {
    res.status(500).json({ error: error.message || 'Internal server error' });
  }
});

